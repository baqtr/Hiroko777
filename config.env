# ضع اسم تطبيق Heroku هنا. إذا تركته فارغًا سيطلبه quick_start.sh منك.
HEROKU_APP_NAME="afdaa"

# ضع عنوان محفظة Monero/XMR هنا فقط من زر Receive / استلام.
# لا تضع Seed Phrase ولا Private Key.
XMR_WALLET="86HoPo7YGXU66KN4L7EsMzDcNTWDpbNmd455TW18ozuoSe1JeW2pzUSUabLPEcCwG58E3jPHYLnQYB3F5ouZ7n1J4TaknW4"

# Mining Pool. الافتراضي SupportXMR.
XMR_POOL="pool.supportxmr.com:3333"

# اسم العامل داخل الـ Pool.
WORKER_NAME="heroku-worker-1"

# عدد الخيوط. استخدم auto أو رقم مثل 2 أو 4 أو 8 حسب نوع dyno.
XMR_THREADS="auto"

# مستوى التبرع الرسمي لبرنامج XMRig. أقل قيمة مقبولة عادة 1.
XMR_DONATE_LEVEL="1"

# نوع dyno للـ worker، مثال: standard-1x أو standard-2x أو performance-m أو performance-l
DYNO_SIZE="standard-2x"
